# ──────────────────────────────────────────────────────────
# Agentic AI Frontend — Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values.
#
# VITE_API_BASE_URL
#   The base URL of the Django backend API.
#   - Development (Vite proxy):  leave empty or set to ""
#   - Production (same origin):  leave empty or set to ""
#   - Production (cross-origin): set to full URL, e.g.
#     https://your-backend.onrender.com
# ──────────────────────────────────────────────────────────
VITE_API_BASE_URL=
